GATEWAY_AUTH_MODE=single_token       # "single_token" or "redis_gateways"
XRPL_RPC_URL=https://s1.ripple.com:51234
MY_DESTINATION_ADDRESS=rYourXRPLReceivingAddressHere1234567890...
FACILITATOR_BEARER_TOKEN=replace-with-a-random-shared-secret
REDIS_URL=redis://127.0.0.1:6379/0   # use redis://redis:6379/0 in Docker Compose
NETWORK_ID=xrpl:0                    # xrpl:0 = mainnet, xrpl:1 = testnet
SETTLEMENT_MODE=validated           # "validated" (recommended) or "optimistic"
VALIDATION_TIMEOUT=15
MIN_XRP_DROPS=1000                  # 0.001 XRP minimum
ALLOWED_ISSUED_ASSETS=              # optional extra CODE:ISSUER pairs beyond built-in RLUSD/USDC
ENABLE_API_DOCS=false               # set true only for local dev or trusted internal access
MAX_REQUEST_BODY_BYTES=32768        # reject oversized payment requests before route handling
REPLAY_PROCESSED_TTL_SECONDS=604800 # 7 days of Redis replay markers
MAX_PAYMENT_LEDGER_WINDOW=20        # public-mode freshness window in ledgers
